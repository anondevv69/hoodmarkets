# Copy to web/.env.local for local dev
VITE_API_URL=http://localhost:3000
VITE_PRIVY_APP_ID=

# Production (Vercel → Settings → Environment Variables):
# VITE_API_URL=https://api.hood.markets
# VITE_PRIVY_APP_ID=<Privy app ID — same as Railway PRIVY_APP_ID>
# Optional: IPFS gateway for token logos (rewrites broken lighthouse gateway URLs)
# VITE_IPFS_GATEWAY_URL=https://alternative-sparrow-qk8yx.lighthouseweb3.xyz/ipfs
# Optional: Robinhood swap feed for Live Trades (defaults to NOXA indexer URL)
# VITE_ROBINHOOD_TRADES_API_URL=https://awk00kk00gskkw0o8kc488kg.notoriouslywrong.com/v1/robinhood/trades/latest
