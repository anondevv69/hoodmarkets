# hoodmarkets factory + modules on Robinhood Chain (4663)
# Copy to .env.robinhood and fill DEPLOYER_PRIVATE_KEY (never commit secrets).

DEPLOYER_PRIVATE_KEY=
# 64 hex chars — with or without 0x (script adds 0x if missing)
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

