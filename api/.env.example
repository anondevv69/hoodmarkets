# Required
# 64 hex chars, with or without 0x (no quotes in production env)
DEPLOYER_PRIVATE_KEY=

# ETH for launch-time Univ4EthDevBuy (default 0.0001 if unset or blank) — swap into new pool so TVL shows; launcher wallet pays it. Set 0 to disable.
# DEPLOY_BOND_ETH=0.0001
# Gas limit for deployToken when dev-buy ETH is attached (factory + pool + extension). Default 12M; raise if BaseScan shows "out of gas" at the limit.
# DEPLOY_TOKEN_GAS=12000000

# Optional CREATE2 vanity: mine a salt so new token addresses end with this hex suffix.
# Default is 4004 when unset. Set false / off / 0 to disable.
# VANITY_ADDRESS_SUFFIX=4004
# Max brute-force attempts before giving up (default 1_000_000).
# VANITY_SALT_MAX_ATTEMPTS=1000000
# Parallel simulateContract calls per batch (default 32; try 64 on a good RPC).
# VANITY_SALT_CONCURRENCY=32

NEYNAR_API_KEY=                            # Get from https://neynar.com
NEYNAR_SIGNER_UUID=                        # Bot's Farcaster signer UUID

# Robinhood Chain (4663) — Liquid Protocol
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
# Set after contracts-robinhood/scripts/deploy-robinhood.sh
LIQUID_FACTORY=
LIQUID_FEE_LOCKER=
LIQUID_HOOK_DYNAMIC_FEE_V2=
LIQUID_HOOK_STATIC_FEE_V2=
LIQUID_LP_LOCKER_FEE_CONVERSION=
LIQUID_SNIPER_AUCTION_V2=
LIQUID_UNIV4_ETH_DEV_BUY=

# Optional - legacy alias (same as ROBINHOOD_RPC_URL)
# BASE_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Optional - Telegram
TELEGRAM_BOT_TOKEN=                        # From @BotFather
# Mirror catalog deploys to a group/supergroup (bot must be a member; forum groups use thread ids below)
# TELEGRAM_FEED_CHAT_ID=-100xxxxxxxxxx
# Forum topic ids (from t.me/yourgroup/<topicId>/...) — omit to use legacy single message to chat only
# TELEGRAM_FEED_THREAD_MEME=
# TELEGRAM_FEED_THREAD_X=
# TELEGRAM_FEED_THREAD_DISCORD=
# TELEGRAM_FEED_THREAD_TELEGRAM=
# TELEGRAM_FEED_THREAD_FARCASTER=
# TELEGRAM_FEED_THREAD_WEB=
# TELEGRAM_FEED_THREAD_DEPLOYER_FEE_MATCH=
# Public URL of the Liquid Launcher web app (shown in deploy success — Privy login / export wallet)
# LAUNCHER_WEB_URL=https://your-domain.com

# Optional - Discord (slash commands need both token and Application ID)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=                        # Same as "Application ID" in Discord Developer Portal
# Optional - Discord #launches-style notifications (web deploys mirror slash deploy success embeds)
# DISCORD_FEED_CHANNEL_ID=                # Channel ID where the bot posts successful launches (bot must be in server)
# DISCORD_DEBUG_CHANNEL_ID=                # Optional: errors / debug
# DISCORD_LAUNCH_WEBHOOK_URL=             # Optional: incoming webhook URL (works without bot; for monitoring web-only deploys)

# Optional - X/Twitter auto-posting
X_POSTING_ENABLED=false
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional - Privy (identity-linked fee wallets; same user id as the web app)
# Get from https://dashboard.privy.io
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# When both are set, Discord / X / Farcaster / Telegram use Privy fee wallets by default.
# Set to 'false' to disable and require explicit 0x fee addresses instead.
# USE_PRIVY_WALLETS=false

# Browser deploy CORS: comma-separated exact origins, e.g. https://your-app.lovable.app,http://localhost:5173
# By default, https://*.lovable.app, *.lovable.dev, and *.lovableproject.com are also allowed (set WEB_DEPLOY_CORS_ALLOW_LOVABLE=false to disable).
# WEB_DEPLOY_CORS_ORIGINS=https://your-domain.com,http://localhost:5173
# WEB_DEPLOY_CORS_ALLOW_LOVABLE=false

# Optional - Supabase (Image storage — only used when PINATA_JWT and LIGHTHOUSE_API_KEY are unset)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=token-images

# Recommended - Pinata (IPFS) for token images — when set, Lighthouse/Supabase are not used for uploads
# https://docs.pinata.cloud/files/uploading-files
# PINATA_JWT=
# Dedicated gateway from Pinata dashboard (no trailing slash). Default: https://gateway.pinata.cloud/ipfs
# PINATA_GATEWAY_URL=https://your-subdomain.mypinata.cloud/ipfs

# Optional fallback - Lighthouse (IPFS) when PINATA_JWT is unset
# https://docs.lighthouse.storage/quick-start
# LIGHTHOUSE_API_KEY=
# LIGHTHOUSE_IPFS_GATEWAY_URL=https://alternative-sparrow-qk8yx.lighthouseweb3.xyz/ipfs

# Global: same ticker symbol at most once per rolling window (hours), all platforms. 0 = off.
# GLOBAL_TICKER_COOLDOWN_HOURS=24

# Eastern calendar day (US Eastern) caps — 0 = unlimited for that rule
# X_MAX_SELF_FEE_DEPLOYS_PER_DAY=
# MAX_OTHER_FEE_DEPLOYS_PER_EASTERN_DAY=   # WEB_ONLY_MODE defaults to 1 (you launching for others)
# MAX_FEE_RECIPIENT_DEPLOYS_PER_EASTERN_DAY=   # WEB_ONLY_MODE defaults to 1

# Optional rolling caps (last N hours) — add on top of Eastern; 0 = off for that rule
# DEPLOY_RATE_LIMIT_HOURS=24
# MAX_SELF_FEE_DEPLOYS_PER_24H=                 # WEB_ONLY_MODE defaults to 1
# MAX_THIRD_PARTY_FEE_TO_WALLET_PER_24H=        # WEB_ONLY_MODE defaults to 1

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
