# Hood.markets — web-only Railway API (no bots, no Neynar)
# Copy to Railway Variables or local .env for testing

WEB_ONLY_MODE=true
NODE_ENV=production
PORT=3000

DEPLOYER_PRIVATE_KEY=
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# hoodmarkets protocol stack (Robinhood mainnet — HoodMarkets-branded redeploy 2026-07-01)
HOODMARKETS_FACTORY=0xdeBc9bC5c3Ca697493a01e8ac503B590D209d8bD
HOODMARKETS_FEE_LOCKER=0xD588F6F8819Fc0B34fF72300Bb87b8c69C4cD454
HOODMARKETS_HOOK_DYNAMIC_FEE_V2=0x5de599D4363bb9308434351600c34C96D46868CC
HOODMARKETS_HOOK_STATIC_FEE_V2=0xCD9DD3fa11c53cf6aE3d4e4D3fdf7C1f790468cc
HOODMARKETS_LP_LOCKER_FEE_CONVERSION=0x34861965c8eFc302E794C8593404CF17c6e65fF0
HOODMARKETS_SNIPER_AUCTION_V2=0xcbbc3534a892a365c57023c34349300d360f6a1b
HOODMARKETS_UNIV4_ETH_DEV_BUY=0x39ddf0339f9dccef59457a3579de1789c38d5a40
HOODMARKETS_SWAP_HELPER=0x6373285F77ad0a3f5a441439B3D23d16B79aA585

# HoodMarkets V3 simple launcher (Uniswap V3 — DexScreener-friendly)
HOODMARKETS_V3_FACTORY=0xcFE4D69Ac8e5F79a95d99e991162902f68029f09
HOODMARKETS_V3_VAULT=0xe250a07229Bcf29a2cC02d6070beE82252F71C36
HOODMARKETS_V3_LP_LOCKER=0x209eFAA86568f0Ea0E25d1F0E62f92e81c51a72a
HOODMARKETS_V3_PLATFORM_FEE_RECIPIENT=0xbfD1be7a12A9FeF04D281C2D8D0D9EE15b576d98
PLATFORM_FEE_RECIPIENT=0xbfD1be7a12A9FeF04D281C2D8D0D9EE15b576d98
HOODMARKETS_DEFAULT_LAUNCH_MODE=simple
# Optional deploy-only (allowlist script): HOODMARKETS_MEV_DESCENDING_FEES=0x31d7d1396dda00110a8984cc7dd4a04fb211379d
# Legacy LIQUID_* names still work as fallbacks if unset above

PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Bankr / agent deploy + claim (haiku captcha JWT, HS256). Generate: openssl rand -hex 32
AGENT_CAPTCHA_JWT_SECRET=
# Channels that skip haiku (default: x,twitter). X agents confirm in-thread; other agents use haiku.
# AGENT_DEPLOY_SKIP_CAPTCHA_CHANNELS=x,twitter
# Legacy: skip haiku for ALL channels (not recommended — use channel list instead)
# AGENT_DEPLOY_SKIP_CAPTCHA=true

# Free X/Bankr launches per wallet per Eastern day (default 1; 0 = unlimited).
# AGENT_X_MAX_DEPLOYS_PER_EASTERN_DAY=1

WEB_DEPLOY_CORS_ORIGINS=https://hood.markets,https://www.hood.markets
WEB_DEPLOY_CORS_ALLOW_LOVABLE=false
# Allow Vercel preview URLs (https://*.vercel.app) — set false once frontend is hood.markets only
WEB_DEPLOY_CORS_ALLOW_VERCEL=true
LAUNCHER_WEB_URL=https://hood.markets
HOODMARKETS_DEPLOY_CONTEXT_PLATFORM=hoodmarkets

# Rate limits (hood.markets defaults)
GLOBAL_TICKER_COOLDOWN_HOURS=24
MAX_SELF_FEE_DEPLOYS_PER_24H=1
DEPLOY_RATE_LIMIT_HOURS=24
STRICT_DEPLOY_RATE_LIMITS=true

# Launch-time WETH seed — paid by launcher wallet only (DEPLOYER_PRIVATE_KEY), not users.
# Web deploys always use exactly this amount. Users add extra liquidity from their own wallet after launch.
DEPLOY_BOND_ETH=0.002

# Brand protection (blocked names/tickers — also has hood.markets defaults when WEB_ONLY_MODE=true)
# NAME_BLOCKLIST=My Other Brand,Another Name
# TICKER_BLOCKLIST=MYBRAND,OTHER

# Required for logo file uploads from the Launch tab (pins images to IPFS for on-chain metadata)
LIGHTHOUSE_API_KEY=

# Platform trading-fee share on normal launches (basis points; 200 = 2%)
PLATFORM_FEE_RECIPIENT=
PLATFORM_FEE_BPS=200

# Local dev — add to WEB_DEPLOY_CORS_ORIGINS when testing web/ locally:
# WEB_DEPLOY_CORS_ORIGINS=https://hood.markets,https://www.hood.markets,http://localhost:5173
# PLATFORM_FEE_RECIPIENT=
# PLATFORM_FEE_BPS=200
